---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sectionPaths } from '../../data/site';

const products = [
	{
		no: '01',
		title: 'ジップアップビブス',
		image: 'https://www.robinfactory.co.jp/wp-content/uploads/2018/04/00036_eye_0903.jpg',
		imageAlt: 'ジップアップビブスの着用イメージ',
		bestFor: 'イベント運営、自治会スタッフ、見守りやボランティアの識別用',
		features: ['吸汗・速乾に優れたメッシュ素材で使いやすい', '前開きで脱ぎ着しやすく、上着の上からも重ねやすい', '発色がよく、スタッフ用やチーム分けでも目立たせやすい'],
		priceLot: '5枚・背中1色で',
		priceNum: '1枚あたり 1,838円(税込)',
	},
	{
		no: '02',
		title: 'ドライメッシュビブス',
		image: 'https://www.robinfactory.co.jp/wp-content/uploads/2018/04/00336_eye202305s.jpg',
		imageAlt: 'ドライメッシュビブスの商品画像',
		bestFor: '自治会の見回り、スポーツイベント、ゼッケン代わりの運用',
		features: ['吸汗・速乾に優れたドライメッシュ素材で軽い', 'スポーツやイベントでも使いやすい発色の良さがある', '自治会の見回りや短時間のスタッフ識別にも向いている'],
		priceLot: '5枚・背中1色で',
		priceNum: '1枚あたり 1,700円(税込)',
	},
	{
		no: '03',
		title: '反射服',
		image: 'https://www.robinfactory.co.jp/wp-content/uploads/2024/09/003923_eye.jpg',
		imageAlt: '反射服の商品画像',
		bestFor: '夜間の交通整理、防犯パトロール、安全確認が必要な現場',
		features: ['反射素材付きで夜間の視認性を確保しやすい', '交通・防犯パトロール用途で使いやすい定番タイプ', '軽い反射アイテムとして役割表示も入れやすい'],
		priceLot: '10枚・背中1色で',
		priceNum: '1枚あたり 2,156円(税込)',
	},
	{
		no: '04',
		title: '反射ビブスベスト',
		image: 'https://www.robinfactory.co.jp/wp-content/uploads/2024/09/035542_eye.jpg',
		imageAlt: '反射ビブスベストの商品画像',
		bestFor: '自治会、地域イベント、防犯当番、備品を持って動くスタッフ用',
		features: ['5つのポケット付きで小物を持って動きやすい', '通気性が高く、長時間の着用でも使いやすい', '反射仕様で地域イベントや見守り活動でも識別しやすい'],
		priceLot: '10枚・背中1色で',
		priceNum: '1枚あたり 2,390円(税込)',
	},
	{
		no: '05',
		title: 'メッシュビブス',
		image: 'https://www.robinfactory.co.jp/wp-content/uploads/2018/04/00007_eye_0903.jpg',
		imageAlt: 'メッシュビブスの商品画像',
		bestFor: 'ボランティア、自治会パトロール、スポーツ、イベント用',
		features: ['軽くて通気性がよく、長時間でも着やすい', 'ボランティアや自治会パトロールでも扱いやすい定番', 'チーム名や背番号、団体名のプリントにも向いている'],
		priceLot: '5枚・背中1色で',
		priceNum: '1枚あたり 1,733円(税込)',
	},
];
---

<BaseLayout
	title="ビブス・反射服の商品と料金｜自治会・防犯パトロール向け名入れ案内"
	description="ジップアップビブス、ドライメッシュビブス、反射服、反射ビブスベスト、メッシュビブスの選び方と料金目安をまとめています。"
	path={sectionPaths.items}
>
	<div class="breadcrumb">
		<a href={sectionPaths.home}>トップ</a>
		<span class="sep">›</span>
		<span>商品と料金</span>
	</div>

	<section class="page-hero">
		<span class="eyebrow">ビブス・反射服の商品一覧</span>
		<h1>自治会・防犯パトロール向けで選ばれやすい商品をまとめました</h1>
		<p class="lead">
			ジップアップビブス、ドライメッシュビブス、反射服、反射ビブスベスト、メッシュビブスなど、実際に比較されやすい商品だけに絞っています。
			夜間の見やすさを重視するのか、軽さや通気性を優先するのかで向く商品が変わるので、まずは使い方に合う種類を見ていただくのが近道です。
		</p>
	</section>

	<section class="section">
		<div class="section-title-bar">
			<h2>自治会・見守り・地域イベントで使いやすい商品一覧</h2>
			<div class="section-sub">ビブスや反射服を比較したい方から相談の多い順に近い並びです</div>
		</div>
		<div class="product-stack">
			{products.map((product) => (
				<article class="product-detail-card">
					<div class="product-no">{product.no}</div>
					<figure class="product-detail-visual">
						<img src={product.image} alt={product.imageAlt} loading="lazy" />
					</figure>
					<div class="product-detail-main">
						<h2>{product.title}</h2>
						<span class="product-best-for">おすすめ用途</span>
						<p class="product-best-for-text">{product.bestFor}</p>
						<ul class="dot-list" style="margin-top: 14px;">
							{product.features.map((feature) => (
								<li>{feature}</li>
							))}
						</ul>
					</div>
					<div class="product-detail-meta">
						<div class="price-chip">{product.priceLot}<br /><span class="price-num">{product.priceNum}</span></div>
					</div>
				</article>
			))}
		</div>
		<p class="table-note" style="margin-top: 18px;">
			※金額は在庫、反射材の仕様、名入れ位置、色数で前後します。まずは比較の目安としてご覧ください。
		</p>
	</section>

	<section class="section">
		<div class="section-title-bar">
			<h2>ビブス・反射服の選び方</h2>
			<div class="section-sub">夜間の視認性を重視するか、軽さや通気性を優先するかで選び方が変わります</div>
		</div>
		<div class="two-col two-col-wide">
			<div>
				<p>
					自治会や見守り活動のご相談でも、夜に使うのか、昼の案内やイベントで使うのかで向く商品は変わります。
					夜間パトロール用は反射服や反射ビブスベスト、日中の見守りやイベント用は軽いビブス、と分けて考えると選びやすくなります。
				</p>
			</div>
			<div class="panel-stack">
				<div class="panel-card">
					<span class="panel-label">夜間活動が中心の場合</span>
					<p>まずは見つけやすさが優先です。反射服や反射ビブスベストのような反射仕様から考えるのが無難です。</p>
				</div>
				<div class="panel-card">
					<span class="panel-label">夏場の見守り活動の場合</span>
					<p>暑さが気になる時期は、軽さと風通しを優先したほうが続けやすいです。ドライメッシュビブスやメッシュビブスが候補に上がりやすくなります。</p>
				</div>
				<div class="panel-card">
					<span class="panel-label">秋冬に上着の上から着る場合</span>
					<p>サイズ感と着脱のしやすさが大事です。上着の上から着る前提なら、ジップアップビブスのような前開きタイプも使いやすくなります。</p>
				</div>
			</div>
		</div>
	</section>

	<section class="cta-banner">
		<div>
			<span class="section-kicker">見積は無料です</span>
			<h2>どの商品が合うか迷う場合は、用途からお聞かせください！</h2>
			<p>夜の巡回なのか、日中の見守りなのか、地域イベント用なのか。そのあたりから伺えれば、候補をかなり絞ってご提案しやすくなります。</p>
		</div>
		<a class="button button-primary" href={sectionPaths.estimate}>見積フォームへ進む<span class="arrow">›</span></a>
	</section>
</BaseLayout>
