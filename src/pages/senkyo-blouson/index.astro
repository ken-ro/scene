---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { futureScenePaths } from '../../data/site';
---

<BaseLayout
	title="選挙ブルゾン・選挙ジャンパーの名入れプリント専門店"
	description="選挙活動用ブルゾン・ジャンパーの名入れプリント案内ページです。"
	path={futureScenePaths.senkyoBlouson}
>
	<section class="page-hero">
		<span class="eyebrow">準備中</span>
		<h1>選挙活動用ブルゾン・ジャンパーの名入れプリント</h1>
		<p class="lead">
			このシーン向けページは、同じ親プロジェクト配下で順次構築していきます。選挙ブルゾン、選挙ジャンパー向けの構成をここに集約する予定です。
		</p>
	</section>
</BaseLayout>