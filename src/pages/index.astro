---
import '../styles/global.css';
import { sceneEntries } from '../data/site';
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>シーン別名入れプリント専門サイト｜プリントロビン</title>
		<meta
			name="description"
			content="シーン別名入れプリント専門サイトの入口です。防犯ベスト、選挙ブルゾン、消防団向けベストなどを用途別に案内します。"
		/>
	</head>
	<body>
		<div class="page-shell">
			<main class="page-main">
				<div class="container">
					<section class="page-hero" style="margin-top: 40px;">
						<span class="eyebrow">scene</span>
						<h1>シーン別名入れプリント専門サイト</h1>
						<p class="lead">
							用途ごとに入口を分けて、防犯ベスト、選挙ブルゾン、消防団・防災活動ベストなどの名入れプリント案内をまとめて見られる構成にしていきます。
						</p>
					</section>

					<section class="section">
						<div class="section-title-bar">
							<h2>現在の公開状況</h2>
							<div class="section-sub">まずは防犯ベスト系を公開し、他シーンを同じ命名規則で順次追加していく想定です</div>
						</div>
						<div class="info-grid">
							{sceneEntries.map((entry) => (
								<article class="info-card">
									<div class="section-kicker" style="margin-bottom: 10px;">{entry.status}</div>
									<h2 style="font-size: 1.45rem; margin-bottom: 10px;">{entry.label}</h2>
									<p>{entry.description}</p>
									{entry.status === '公開中' ? (
										<a class="button button-primary" href={entry.href} style="margin-top: 18px; display: inline-flex;">ページを開く<span class="arrow">›</span></a>
									) : (
										<span class="button button-secondary" style="margin-top: 18px; display: inline-flex; opacity: 0.75; pointer-events: none;">準備中</span>
									)}
								</article>
							))}
						</div>
					</section>
				</div>
			</main>
		</div>
	</body>
</html>