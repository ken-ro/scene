---
import { sectionPaths } from '../data/site';

interface Props {
	currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const navItems = [
	{ href: sectionPaths.home, label: 'トップ' },
	{ href: sectionPaths.items, label: '商品と料金' },
	{ href: sectionPaths.guide, label: '用途ガイド' },
	{ href: sectionPaths.estimate, label: '見積と相談' },
];
---

<header class="site-header">
	<div class="info-bar">
		<div class="info-bar-inner">
			<div class="info-bar-left">運営：株式会社ロビンファクトリー</div>
			<div class="info-bar-right">
				<span>営業時間　月曜-金曜 10:30 - 18:00（日・祝日を除く）</span>
				<a href="tel:05037338888">
					<svg class="info-bar-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.05-.24 11.36 11.36 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A18 18 0 013 5a1 1 0 011-1h3.49a1 1 0 011 1 11.36 11.36 0 00.57 3.58 1 1 0 01-.24 1.05l-2.2 2.16z"/></svg>
					050-3733-8888
				</a>
				<a href={sectionPaths.estimate}>無料見積</a>
			</div>
		</div>
	</div>

	<div class="container">
		<div class="masthead">
			<a class="brand-link" href={sectionPaths.home}>
				<span class="brand-eyebrow">自治会・町内会・見守り隊向け</span>
				<span class="brand-name">防犯ベスト・自治会ビブス名入れ専門店</span>
				<span class="brand-sub">防犯・見守り・地域行事で使う名入れベストを、実際の使い方に合わせて見ていけます</span>
			</a>
			<div class="contact-block">
				<span class="contact-label">お電話でのご相談</span>
				<span class="contact-tel">
					<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.05-.24 11.36 11.36 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A18 18 0 013 5a1 1 0 011-1h3.49a1 1 0 011 1 11.36 11.36 0 00.57 3.58 1 1 0 01-.24 1.05l-2.2 2.16z"/></svg>
					050-3733-8888
				</span>
				<span class="contact-hours">営業時間　月曜-金曜 10:30 - 18:00（日・祝日を除く）</span>
			</div>
		</div>

		<div class="site-nav-wrap">
			<nav class="site-nav" aria-label="主要メニュー">
				{navItems.map((item) => (
					<a class:list={["nav-link", currentPath === item.href && 'is-active']} href={item.href}>{item.label}</a>
				))}
			</nav>
			<a class="nav-cta" href={sectionPaths.order}>ご注文フォーム<span class="nav-cta-arrow">›</span></a>
		</div>
	</div>
</header>

